# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/
dist/
# (build/ — was Python sdist; now used for corpus pipeline; specific files
# listed lower down)
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Audio samples (large files, gitignore by default — share separately)
samples/*.mp3
samples/*.wav
samples/*.m4a
samples/*.flac
samples/*.ogg
!samples/.gitkeep
!samples/README.md

# Models (Whisper weights are large)
models/
*.bin
*.pt
*.onnx

# Data (corpus can be large)
data/sggs/*.json
data/sggs/*.db
data/sggs/*.sqlite
!data/sggs/.gitkeep

# Eval runs
eval_runs/

# Evaluation transcript cache (regenerated by scripts/evaluate.py)
evaluation/.cache/

# Build artifacts (regenerated by build/ pipeline)
build/intermediate_unicode.sqlite
build/app_database.sqlite
build/node_modules/
build/package-lock.json

# Swift Package build artifacts
ios/*/.build/
ios/*/.swiftpm/

# Spike artifacts (regenerable)
docs/aeneas_spike_alignment.json

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Environment
.env
.env.local
*.log

# Server
server/node_modules/
server/package-lock.json
server/.venv-asr/
server/test-fixtures/
server/data/*.db
server/data/*.db-journal
server/data/*.db-wal
server/data/*.db-shm
!server/data/.gitkeep

# XcodeGen-generated project files (regenerate with `xcodegen generate`)
ios/GurbaniLens/GurbaniLens.xcodeproj/
ios/GurbaniLens/GurbaniLens.xcworkspace/

# iOS Resources fetched at build time (whisper models + app db live in bundle Resources).
# Populated by scripts/fetch_ios_deps.sh — keep large binaries out of the repo.
ios/GurbaniLens/GurbaniLens/Resources/Models/
ios/GurbaniLens/GurbaniLens/Resources/Database/
ios/GurbaniLens/GurbaniLens/Resources/Data/
build/ios-deps-cache/

# Whisper conversion artifacts
build/whisper.cpp/

# Dataset audio is symlinked/copied from samples/ (which is gitignored upstream).
# Alignments, splits, manifest, and README *are* checked in — those are our
# original CC-BY-SA-4.0 contribution.
dataset/audio/

# Android binary deps populated by scripts/fetch_android_deps.sh.
# Whisper prebuilt .so + bundled GGML model + bundled SGGS DB are large and
# re-downloadable, so we keep them out of the repo and let the fetch script
# reconstruct them. (.bin and .so are already covered by the broad patterns
# above; these explicit entries document the contract.)
android/app/src/main/jniLibs/
android/app/src/main/assets/ggml-*.bin
android/app/src/main/assets/sggs.sqlite
build/android-deps-cache/
