# GurbaniLens server config. Copy to .env and edit. .env is gitignored.

PORT=8443
HOST=0.0.0.0

# Set to 1 in dev to skip loading the Whisper model. Endpoint shapes still
# work but /transcribe returns "not_implemented".
WHISPER_DISABLED=0

# Path to ggml model on the deployed host. Not used when WHISPER_DISABLED=1.
WHISPER_MODEL_PATH=/var/lib/gurbanilens/models/ggml-large-v3.bin

# Where to queue user-submitted corrections. The directory must be on a
# disk we control; encryption-at-rest is the filesystem's responsibility
# (configure LUKS / equivalent on the host).
FEEDBACK_QUEUE_DIR=/var/lib/gurbanilens/feedback-queue
