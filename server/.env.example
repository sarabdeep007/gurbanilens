# GurbaniLens server config. Copy to .env and edit. .env is gitignored.

# --- network ---
PORT=4040
HOST=0.0.0.0
LOG_LEVEL=info

# --- ASR ---
# Set to 1 in dev to skip Whisper entirely. /transcribe returns 503
# not_implemented; everything else still works.
WHISPER_DISABLED=0

# faster-whisper model name. Production: large-v3 (~3 GB download).
# Dev smoke test: tiny (~75 MB) or base (~140 MB).
WHISPER_MODEL=large-v3

# Path to the Python interpreter that has faster-whisper installed.
# Default assumes a sibling .venv-asr created via:
#   uv venv .venv-asr && uv pip install --python .venv-asr/bin/python faster-whisper
WHISPER_PYTHON=./.venv-asr/bin/python

# Path to the worker script (rarely overridden).
WHISPER_WORKER=./src/asr/whisper_worker.py

# --- feedback channel ---
# SQLite file for /feedback persistence.
FEEDBACK_DB_PATH=./data/feedback.db

# Set to 1 to refuse /feedback/* with 503; useful for dev / testing.
FEEDBACK_DISABLED=0

# HMAC secret for session-token hashing on insert. Must be ≥16 chars.
# IMPORTANT: in production, generate a fresh random value, e.g.
#   openssl rand -hex 32
# and treat it as a long-lived secret (rotating it strands all extant
# "view my submissions / delete all" session linkages).
FEEDBACK_HMAC_SECRET=dev-only-change-me-32-chars-or-more-please-do-not-use-in-prod
