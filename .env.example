# GurbaniLens cloud ASR API keys.
#
# Copy this file to `.env` at the repo root and populate the keys you
# have access to. Keys are injected into the iOS app's Info.plist at
# build time by `scripts/inject_env_to_plist.sh` (wired as a
# postBuildScript in ios/GurbaniLens/project.yml).
#
# `.env` is in .gitignore — do not commit real keys.
#
# Both keys are optional. A missing key disables that cloud provider;
# the Settings → Voice recognition → Cloud picker will still let you
# pick the provider, but starting it will throw "missing key" and the
# user can fall back to WhisperKit (the local default).
#
# Long-term we'll proxy these through Taaj backend (api.taajsingh.com)
# so the keys never ship to user devices. v1 is direct-to-provider for
# the Compare-mode A/B test only.

# GurbaniLens self-hosted ASR (v1 production default) — IndicConformer
# Punjabi at asr.gurbanilens.com. Free for end users, bearer-token
# authenticated server-side. Without these the iOS app falls back to
# on-device Whisper-medium when the user enables cloud.
# The URL is public; the token is provisioned per-build and lives in
# the server's .env on taaj-prod. Ask Deep for the current token.
GURBANILENS_ASR_URL=https://asr.gurbanilens.com/transcribe
GURBANILENS_ASR_TOKEN=

# Sarvam Saaras-v3 streaming ASR (Indian language SOTA, ₹30/hour).
# HIDDEN from the user-facing picker as of 2026-06-25 — GurbaniLens
# Cloud covers the same role for free. SarvamProvider still ships and
# is used internally by DualLiveProvider + Compare-mode debug. Leave
# the key blank unless you need Compare mode or Dual.
SARVAM_API_KEY=

# Google Gemini 2.5 Flash (multimodal). HIDDEN from the user-facing
# picker (a05f144) — hallucinates Gurbani sacred text. Compare-mode
# debug only.
GEMINI_API_KEY=
